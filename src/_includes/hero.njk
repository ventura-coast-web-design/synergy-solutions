<section class="hero" aria-labelledby="hero-heading">
    <div class="hero__inner">
        <h1 id="hero-heading" class="hero__headline">
            <span class="hero__headline-line">Empowering</span>
            <span class="hero__headline-line hero__headline-line--accent">Your Team</span>
        </h1>

        <div class="hero__card">
            <div class="hero__card-body">
                <p class="hero__subhead">
                    <span class="hero__circle-word">Inspiring</span>
                    team <strong class="hero__highlight">connection</strong>, <strong class="hero__highlight">engagement</strong>, and <strong class="hero__highlight">loyalty</strong>
                    in an age of <span class="hero__squiggle">growing</span> disconnection.
                </p>
                <div class="hero__actions">
                    <a href="/contact" class="hero__btn hero__btn--primary">Book Jonathan</a>
                    <a href="#watch" class="hero__btn hero__btn--ghost">
                        <span class="hero__play" aria-hidden="true"></span>
                        Watch Jonathan in action
                    </a>
                </div>
            </div>

            <div class="hero__figure">
                <img
                    src="/assets/images/jonny.png"
                    alt="Jonathan Wisnieski, keynote speaker"
                    class="hero__photo"
                    width="520"
                    height="640"
                    decoding="async"
                >
                <p class="hero__credentials">
                    Keynote speaker<br>
                    Leadership &amp; team culture<br>
                    Synergy Solutions
                </p>
            </div>
        </div>
    </div>
</section>
